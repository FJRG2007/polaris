// Polaris data model.
//
// Design constraints (do not relitigate):
//   - Postgres in production, but kept SQLite-portable: no Postgres-only column
//     types beyond the id type, no native enums (String + app-level Zod unions),
//     no scalar arrays or JSONB columns (JSON is stored as a stringified String).
//     The gen-sqlite-schema script swaps the datasource provider and strips the
//     Postgres-only @db.Uuid mapping (SQLite stores the uuid as TEXT).
//   - Every surrogate primary key and id reference is a UUIDv7 stored in a native
//     Postgres `uuid` column (@db.Uuid). Natural keys (GeoIpCache.ip) stay text.
//   - Byte counts use BigInt (files can exceed 2^53) and are handled as bigint
//     in application code, never coerced through a lossy Number.
//   - Polaris is a control plane, not a file mirror: the Node table holds rows
//     only for objects Polaris must track (shared or requested items). Live
//     directory listings come from the storage driver and are never persisted.
//   - better-auth owns the User/Session/Account/Verification core fields; the
//     extra columns and the Role/UserRole tables are Polaris additions. better-auth
//     is configured to generate UUIDs so its inserts fit the uuid columns.

generator client {
    provider = "prisma-client-js"
    output   = "../generated/client"
}

datasource db {
    provider = "postgresql"
    url      = env("POLARIS_DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Identity and access
// ---------------------------------------------------------------------------

model User {
    id            String   @id @default(uuid(7)) @db.Uuid
    name          String
    email         String   @unique
    // Unique handle; sign-in accepts either this or the email.
    username      String?  @unique
    emailVerified Boolean  @default(false)
    image         String?
    // Second gate for admin-only routes, independent of role permissions.
    isAdmin       Boolean  @default(false)
    // When set, the account is banned: sign-in is refused and sessions are void.
    bannedAt      DateTime?
    banReason     String?
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt

    sessions     Session[]
    accounts     Account[]
    roles        UserRole[]
    groups       GroupMember[]
    invitesSent  Invite[]                @relation("InviteInviter")
    connections       StorageConnection[]
    dockerConnections DockerConnection[]
    hosts             Host[]
    shares            Share[]
    shareInvites      ShareInvite[]
    fileRequests      FileRequest[]
    submissions       FileRequestSubmission[]
    uploads           UploadSession[]
    notifications     Notification[]
    deployTargets     DeployTarget[]
    projects          Project[]
    deployTickets     DeployTicket[]
}

model Session {
    id        String   @id @default(uuid(7)) @db.Uuid
    token     String   @unique
    expiresAt DateTime
    ipAddress String?
    userAgent String?
    userId    String   @db.Uuid
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
}

model Account {
    id                    String    @id @default(uuid(7)) @db.Uuid
    accountId             String
    providerId            String
    userId                String    @db.Uuid
    accessToken           String?
    refreshToken          String?
    idToken               String?
    accessTokenExpiresAt  DateTime?
    refreshTokenExpiresAt DateTime?
    scope                 String?
    password              String?
    createdAt             DateTime  @default(now())
    updatedAt             DateTime  @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
}

model Verification {
    id         String   @id @default(uuid(7)) @db.Uuid
    identifier String
    value      String
    expiresAt  DateTime
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt

    @@index([identifier])
}

model Role {
    id          String     @id @default(uuid(7)) @db.Uuid
    name        String     @unique
    // JSON array of permission keys (or the "*" wildcard). Stored as a string
    // for SQLite portability; validated by @polaris/core on read.
    permissions String
    isSystem    Boolean    @default(false)
    createdAt   DateTime   @default(now())
    users       UserRole[]
}

model UserRole {
    userId String @db.Uuid
    roleId String @db.Uuid
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
    role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

    @@id([userId, roleId])
    @@index([roleId])
}

model Invite {
    id          String    @id @default(uuid(7)) @db.Uuid
    email       String
    // SHA-256 of the invite token; the raw token lives only in the emailed link.
    tokenHash   String    @unique
    roleId      String?   @db.Uuid
    invitedById String    @db.Uuid
    expiresAt   DateTime
    acceptedAt  DateTime?
    createdAt   DateTime  @default(now())

    invitedBy User @relation("InviteInviter", fields: [invitedById], references: [id], onDelete: Cascade)

    @@index([email])
}

// A named bundle of users. Policies attach to a group so a grant applies to
// everyone in it; group membership is the cheapest way to manage access at scale.
model Group {
    id          String        @id @default(uuid(7)) @db.Uuid
    name        String        @unique
    description String?
    isSystem    Boolean       @default(false)
    createdAt   DateTime      @default(now())
    members     GroupMember[]
}

model GroupMember {
    groupId String @db.Uuid
    userId  String @db.Uuid
    group   Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
    user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@id([groupId, userId])
    @@index([userId])
}

// A reusable authorization policy: a JSON document of allow/deny statements over
// (action, resource) patterns, evaluated by @polaris/core's engine. Attaching a
// policy to a user, group, or role folds its statements into that principal's
// effective permissions. Deny-by-default; an explicit deny overrides any allow.
model Policy {
    id          String             @id @default(uuid(7)) @db.Uuid
    name        String             @unique
    description String?
    // Stringified PolicyDocument JSON (SQLite-portable); validated on read/write.
    document    String
    isSystem    Boolean            @default(false)
    createdAt   DateTime           @default(now())
    updatedAt   DateTime           @updatedAt
    attachments PolicyAttachment[]
}

// Binds a policy to a principal. principalType is "user" | "group" | "role" and
// principalId is that principal's id; kept generic (no FK) so one table covers
// all three without three near-identical join tables.
model PolicyAttachment {
    id            String @id @default(uuid(7)) @db.Uuid
    policyId      String @db.Uuid
    principalType String
    principalId   String @db.Uuid

    policy Policy @relation(fields: [policyId], references: [id], onDelete: Cascade)

    @@unique([policyId, principalType, principalId])
    @@index([principalType, principalId])
}

// A per-path Drive access-control entry: grants (or denies) a principal a set of
// Drive verbs on a connection subtree. Applies to the path and everything under
// it. This is what lets a connection owner share specific folders with other
// users/groups without handing over the whole connection.
model DriveAcl {
    id            String   @id @default(uuid(7)) @db.Uuid
    connectionId  String   @db.Uuid
    // "" means the whole connection; otherwise the subtree root (normalized).
    path          String   @default("")
    principalType String
    principalId   String   @db.Uuid
    // JSON array of Drive verbs: read, write, rename, delete, copy, download.
    actions       String
    effect        String   @default("allow")
    createdById   String   @db.Uuid
    createdAt     DateTime @default(now())

    connection StorageConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

    @@index([connectionId])
    @@index([principalType, principalId])
}

// A password gate ("Polaris access gate") on a Drive path. Browsing, opening, or
// downloading anything at or under a locked path requires unlocking it with the
// password first; the unlock is remembered in a signed, per-lock session cookie.
// The password is stored with the same slow, salted KDF as share/link passwords.
model AccessLock {
    id           String   @id @default(uuid(7)) @db.Uuid
    connectionId String   @db.Uuid
    path         String
    passwordHash String
    createdById  String   @db.Uuid
    createdAt    DateTime @default(now())

    connection StorageConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

    @@unique([connectionId, path])
    @@index([connectionId])
}

// ---------------------------------------------------------------------------
// Storage
// ---------------------------------------------------------------------------

model StorageConnection {
    id                  String   @id @default(uuid(7)) @db.Uuid
    name                String
    kind                String
    ownerId             String   @db.Uuid
    // Non-secret connection config (host, port, share path) as JSON string.
    config              String
    // Envelope-encrypted credentials (AES-256-GCM). Null for anonymous providers.
    encryptedCredential Bytes?
    credentialNonce     Bytes?
    credentialKeyId     String?
    requiresHostd       Boolean  @default(false)
    status              String   @default("active")
    createdAt           DateTime @default(now())
    updatedAt           DateTime @updatedAt

    owner        User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
    mount        StorageMount?
    nodes        Node[]
    shares       Share[]
    fileRequests FileRequest[]
    uploads      UploadSession[]
    itemMeta     DriveItemMeta[]
    trashItems   TrashItem[]
    acls         DriveAcl[]
    locks        AccessLock[]
    scheduledDeletions ScheduledDeletion[]
    deployVolumes      Volume[]

    @@index([ownerId])
}

// A deletion scheduled for a future time. Polaris has no always-on scheduler, so
// due rows are swept lazily (whenever the connection is next browsed) and by an
// optional cron endpoint for exact timing - the same lazy-evaluation approach the
// rest of the app uses for share/link expiry. `permanent` picks delete-for-good
// over the recycle bin.
model ScheduledDeletion {
    id           String   @id @default(uuid(7)) @db.Uuid
    ownerId      String   @db.Uuid
    connectionId String   @db.Uuid
    path         String
    name         String
    permanent    Boolean  @default(false)
    deleteAt     DateTime
    createdAt    DateTime @default(now())

    connection StorageConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

    @@index([ownerId])
    @@index([connectionId])
    @@index([deleteAt])
}

// A Polaris-managed recycle bin entry. "Move to Trash" relocates the item into a
// hidden trash folder on the same connection and records where it came from, so
// it can be listed, restored to its original path, or permanently deleted. Works
// for any backend; UniFi UNAS keeps its own trash, which can be reused later.
model TrashItem {
    id           String   @id @default(uuid(7)) @db.Uuid
    ownerId      String   @db.Uuid
    connectionId String   @db.Uuid
    name         String
    // Where it lived before deletion, and where it now sits in the trash folder.
    originalPath String
    trashPath    String
    kind         String
    size         BigInt   @default(0)
    deletedAt    DateTime @default(now())

    connection StorageConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

    @@index([ownerId])
    @@index([connectionId])
}

// Per-path presentation metadata for a browsed item (not a mirror of the tree):
// custom icon, hidden flag. Keyed by (connection, path); rows exist only for
// items the user has customized. Cascades away with its connection.
model DriveItemMeta {
    id           String   @id @default(uuid(7)) @db.Uuid
    ownerId      String   @db.Uuid
    connectionId String   @db.Uuid
    path         String
    hidden       Boolean  @default(false)
    favorite     Boolean  @default(false)
    // The Polaris user who uploaded/created this item, when known (drop-point
    // uploads, dashboard uploads, new files/folders, copies). Null for items that
    // predate Polaris or were created out of band. Follows the item on move/rename.
    creatorId    String?  @db.Uuid
    icon         String?
    iconColor    String?
    note         String?
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt

    connection StorageConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

    @@unique([connectionId, path])
    @@index([ownerId])
}

model DockerConnection {
    id                  String   @id @default(uuid(7)) @db.Uuid
    name                String
    ownerId             String   @db.Uuid
    // socket | ssh | tcp
    transport           String
    // Non-secret transport config (host, port, socket path) as JSON string.
    config              String
    // Envelope-encrypted credentials (pasted SSH key / TLS certs). Null for the
    // socket transport and for SSH using the install-provisioned key.
    encryptedCredential Bytes?
    credentialNonce     Bytes?
    credentialKeyId     String?
    status              String   @default("active")
    createdAt           DateTime @default(now())
    updatedAt           DateTime @updatedAt

    owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

    @@index([ownerId])
}

// A global server registered once (SSH) and consumed by multiple apps: Docker
// over SSH in Containers, and SFTP browsing in Drive.
model Host {
    id                  String   @id @default(uuid(7)) @db.Uuid
    name                String
    ownerId             String   @db.Uuid
    // SSH endpoint.
    address             String
    port                Int      @default(22)
    username            String
    // password | key
    authMethod          String
    // Server public key (base64) pinned on the trust-on-add test connect.
    hostKey             String?
    // Envelope-encrypted credentials (password, or private key + passphrase).
    encryptedCredential Bytes?
    credentialNonce     Bytes?
    credentialKeyId     String?
    status              String   @default("active")
    createdAt           DateTime @default(now())
    updatedAt           DateTime @updatedAt

    owner         User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
    deployTargets DeployTarget[]

    @@index([ownerId])
}

model StorageMount {
    id            String    @id @default(uuid(7)) @db.Uuid
    connectionId  String    @unique @db.Uuid
    mountPath     String
    state         String    @default("pending")
    error         String?
    lastCheckedAt DateTime?
    createdAt     DateTime  @default(now())

    connection StorageConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
}

model Node {
    id           String   @id @default(uuid(7)) @db.Uuid
    connectionId String   @db.Uuid
    path         String
    kind         String
    size         BigInt   @default(0)
    mime         String?
    etag         String?
    ownerId      String?  @db.Uuid
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt

    connection  StorageConnection       @relation(fields: [connectionId], references: [id], onDelete: Cascade)
    shares      Share[]
    submissions FileRequestSubmission[]

    @@unique([connectionId, path])
    @@index([connectionId])
}

// ---------------------------------------------------------------------------
// Sharing (files out)
// ---------------------------------------------------------------------------

model Share {
    id            String    @id @default(uuid(7)) @db.Uuid
    connectionId  String    @db.Uuid
    // Snapshot of the shared path; a Node row backs it when a stable referent is
    // needed (the remote file may be listed live and can vanish out of band).
    path          String
    nodeId        String?   @db.Uuid
    ownerId       String    @db.Uuid
    kind          String    @default("public")
    // SHA-256 of the share token; lookups are by hash so a DB dump yields no links.
    tokenHash     String    @unique
    // The token, envelope-encrypted under the master key, so the owner can reveal
    // the link again after creation. A DB dump alone still yields no working links.
    encryptedToken Bytes?
    tokenNonce     Bytes?
    tokenKeyId     String?
    // argon2 hash of the optional link password.
    passwordHash  String?
    maxDownloads  Int?
    downloadCount Int       @default(0)
    expiresAt     DateTime?
    allowUpload   Boolean   @default(false)
    // Whether recipients may download the bytes / preview inline in the browser.
    allowDownload Boolean   @default(true)
    allowPreview  Boolean   @default(true)
    // JSON string array of IP/CIDR rules; empty means anyone with the link.
    allowedCidrs  String    @default("[]")
    // JSON string arrays of ISO country codes / continent codes; empty means no
    // geo restriction. Enforced server-side per access after resolving the IP.
    allowedCountries  String @default("[]")
    allowedContinents String @default("[]")
    createdAt     DateTime  @default(now())
    revokedAt     DateTime?

    connection StorageConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
    node       Node?             @relation(fields: [nodeId], references: [id], onDelete: SetNull)
    owner      User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
    invites    ShareInvite[]
    accessLogs ShareAccessLog[]

    @@index([ownerId])
    @@index([connectionId])
}

model ShareInvite {
    id         String @id @default(uuid(7)) @db.Uuid
    shareId    String @db.Uuid
    userId     String @db.Uuid
    permission String @default("download")

    share Share @relation(fields: [shareId], references: [id], onDelete: Cascade)
    user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([shareId, userId])
    @@index([userId])
}

model ShareAccessLog {
    id            String   @id @default(uuid(7)) @db.Uuid
    shareId       String   @db.Uuid
    at            DateTime @default(now())
    // Client IP is stored hashed for privacy while still supporting abuse review.
    ipHash        String?
    // Raw client IP, shown to the share owner in the access log (their own link).
    ip            String?
    userAgentHash String?
    action        String
    reason        String?

    share Share @relation(fields: [shareId], references: [id], onDelete: Cascade)

    @@index([shareId])
}

// ---------------------------------------------------------------------------
// File requests (files in)
// ---------------------------------------------------------------------------

model FileRequest {
    id                      String    @id @default(uuid(7)) @db.Uuid
    ownerId                 String    @db.Uuid
    tokenHash               String    @unique
    title                   String
    instructions            String?
    destinationConnectionId String    @db.Uuid
    destinationPath         String
    requireLogin            Boolean   @default(false)
    // argon2 hash of an optional access PIN/password gating the upload page.
    passwordHash            String?
    maxSizeBytes            BigInt
    maxFiles                Int?
    // JSON string arrays validated by @polaris/core.
    allowedExtensions       String    @default("[]")
    allowedMimeTypes        String    @default("[]")
    allowedCidrs            String    @default("[]")
    // JSON string arrays of ISO country codes / continent codes; empty means no
    // geo restriction. Enforced server-side per upload after resolving the IP.
    allowedCountries        String    @default("[]")
    allowedContinents       String    @default("[]")
    expiresAt               DateTime?
    createdAt               DateTime  @default(now())
    revokedAt               DateTime?

    owner       User                    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
    destination StorageConnection       @relation(fields: [destinationConnectionId], references: [id], onDelete: Cascade)
    submissions FileRequestSubmission[]

    @@index([ownerId])
}

// Fixed-window rate-limit counters (e.g. password-guess throttling per link+IP).
// A lightweight DB-backed limiter; a distributed deployment can swap in Redis.
model RateLimitCounter {
    id          String   @id @default(uuid(7)) @db.Uuid
    key         String   @unique
    count       Int      @default(0)
    windowStart DateTime @default(now())

    @@index([windowStart])
}

model FileRequestSubmission {
    id                String   @id @default(uuid(7)) @db.Uuid
    requestId         String   @db.Uuid
    submittedByUserId String?  @db.Uuid
    ipHash            String?
    fileName          String
    size              BigInt
    storedNodeId      String?  @db.Uuid
    storedPath        String
    status            String   @default("stored")
    at                DateTime @default(now())

    request     FileRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
    submittedBy User?       @relation(fields: [submittedByUserId], references: [id], onDelete: SetNull)
    storedNode  Node?       @relation(fields: [storedNodeId], references: [id], onDelete: SetNull)

    @@index([requestId])
}

// ---------------------------------------------------------------------------
// Uploads (resumable, both directions)
// ---------------------------------------------------------------------------

model UploadSession {
    id            String   @id @default(uuid(7)) @db.Uuid
    kind          String
    ownerId       String?  @db.Uuid
    connectionId  String   @db.Uuid
    targetPath    String
    totalSize     BigInt
    receivedBytes BigInt   @default(0)
    chunkSize     Int
    // JSON record of received parts (offset + etag) for tus-style resume.
    partsJson     String   @default("[]")
    mime          String?
    fileRequestId String?  @db.Uuid
    status        String   @default("open")
    expiresAt     DateTime
    createdAt     DateTime @default(now())

    owner      User?             @relation(fields: [ownerId], references: [id], onDelete: SetNull)
    connection StorageConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

    @@index([connectionId])
    @@index([status])
}

// ---------------------------------------------------------------------------
// Operations
// ---------------------------------------------------------------------------

model AuditLog {
    id         String   @id @default(uuid(7)) @db.Uuid
    actorId    String?  @db.Uuid
    action     String
    targetType String?
    targetId   String?  @db.Uuid
    metadata   String?
    ipHash     String?
    at         DateTime @default(now())

    @@index([actorId])
    @@index([action])
}

model Setting {
    id     String  @id @default(uuid(7)) @db.Uuid
    key    String  @unique
    value  String
    scope  String  @default("global")
    userId String? @db.Uuid

    @@index([scope])
}

// Cache of resolved IP geolocation, so a country/continent allowlist does not hit
// an external provider on every access and a location is remembered for reuse.
// Keyed by IP (a natural key, not a surrogate uuid); refreshed lazily on age-out.
model GeoIpCache {
    ip          String   @id
    countryCode String?
    country     String?
    continent   String?
    source      String?
    updatedAt   DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Integrations (marketplace) and notifications
// ---------------------------------------------------------------------------

// An installed marketplace integration, one row per provider (instance-wide).
// The catalog of available integrations lives in code; this table records which
// have been enabled and their config. Secret material (an API key) is envelope-
// encrypted with the same AES-256-GCM master key as storage credentials, so a DB
// dump yields no usable keys.
model Integration {
    id              String   @id @default(uuid(7)) @db.Uuid
    // Catalog slug, e.g. "virustotal". One install per provider.
    provider        String   @unique
    enabled         Boolean  @default(false)
    // Non-secret config as a stringified JSON object (SQLite-portable).
    config          String   @default("{}")
    // Envelope-encrypted secret (API key); null until configured.
    encryptedSecret Bytes?
    secretNonce     Bytes?
    secretKeyId     String?
    installedById   String?  @db.Uuid
    createdAt       DateTime @default(now())
    updatedAt       DateTime @updatedAt
}

// An in-app notification for one user. Written by server-side events (e.g. a
// drop-point upload scanned by an integration) and surfaced by the bell and the
// notifications page. Cascades away with the user.
model Notification {
    id        String    @id @default(uuid(7)) @db.Uuid
    userId    String    @db.Uuid
    // Category slug driving the icon, e.g. "scan.malicious", "scan.clean".
    type      String
    title     String
    body      String?
    // Optional in-app deep link (e.g. "/drive/drop-points").
    href      String?
    // Styling severity: info | success | warning | danger.
    level     String    @default("info")
    // Stringified JSON metadata (connectionId, path, submissionId, ...).
    metadata  String?
    readAt    DateTime?
    createdAt DateTime  @default(now())

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId, readAt])
    @@index([userId, createdAt])
}

// The result of an integration scanning a stored file (e.g. VirusTotal on a
// drop-point upload). Kept for the owner's audit trail and to avoid re-scanning
// a known hash. Not FK-bound to the submission so a purged submission does not
// erase the security record.
model FileScan {
    id           String   @id @default(uuid(7)) @db.Uuid
    provider     String   @default("virustotal")
    submissionId String?  @db.Uuid
    connectionId String?  @db.Uuid
    path         String?
    sha256       String?
    // pending | clean | suspicious | malicious | unknown | error | skipped
    verdict      String   @default("pending")
    malicious    Int      @default(0)
    suspicious   Int      @default(0)
    // Provider report permalink, when available.
    permalink    String?
    // Enforcement taken on a detection: none | blocked | quarantined | notified
    action       String   @default("none")
    detail       String?
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt

    @@index([submissionId])
    @@index([sha256])
}

// ---------------------------------------------------------------------------
// Deploy (Railway-style app/database orchestration)
// ---------------------------------------------------------------------------

// The "where it runs" abstraction: the local host (via polaris-hostd) or a
// remote SSH Host (EC2/VPS). Holds the per-server runtime engine and the shared
// proxy network deployed services join. A local target has a null hostId.
model DeployTarget {
    id              String   @id @default(uuid(7)) @db.Uuid
    ownerId         String   @db.Uuid
    name            String
    // local | host
    kind            String   @default("local")
    // Null for the local hostd target; otherwise the SSH Host it runs on.
    hostId          String?  @db.Uuid
    // compose | swarm
    runtime         String   @default("compose")
    // Shared user-defined network deployed services join for name-based DNS.
    proxyNetwork    String   @default("polaris-proxy")
    // Hash of the last applied runtime/proxy config, for idempotency and drift.
    lastAppliedHash String?
    status          String   @default("active")
    createdAt       DateTime @default(now())
    updatedAt       DateTime @updatedAt

    owner        User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
    host         Host?             @relation(fields: [hostId], references: [id], onDelete: Cascade)
    applications Application[]
    databases    ManagedDatabase[]
    deployments  Deployment[]
    volumes      Volume[]

    @@unique([ownerId, name])
    @@index([ownerId])
    @@index([hostId])
}

model Project {
    id          String   @id @default(uuid(7)) @db.Uuid
    ownerId     String   @db.Uuid
    name        String
    slug        String
    description String?
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    owner        User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
    environments Environment[]

    @@unique([ownerId, slug])
    @@index([ownerId])
}

// A private container-registry login, owner-scoped, one per registry host. The
// password is envelope-encrypted at rest; deploys `docker login` before pulling a
// private image whose registry matches.
model RegistryCredential {
    id                String   @id @default(uuid(7)) @db.Uuid
    ownerId           String   @db.Uuid
    // Registry host, e.g. "ghcr.io" or "docker.io" (Docker Hub).
    registry          String
    username          String
    encryptedPassword Bytes
    passwordNonce     Bytes
    passwordKeyId     String
    createdAt         DateTime @default(now())
    updatedAt         DateTime @updatedAt

    @@unique([ownerId, registry])
    @@index([ownerId])
}

model Environment {
    id        String   @id @default(uuid(7)) @db.Uuid
    projectId String   @db.Uuid
    name      String
    slug      String
    isDefault Boolean  @default(false)
    // Canvas layout as stringified JSON: { pos: {serviceId:{x,y}}, links: [{source,target}] }.
    layout    String   @default("{}")
    createdAt DateTime @default(now())

    project      Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
    applications Application[]
    databases    ManagedDatabase[]

    @@unique([projectId, slug])
    @@index([projectId])
}

model Application {
    id                  String    @id @default(uuid(7)) @db.Uuid
    environmentId       String    @db.Uuid
    targetId            String    @db.Uuid
    name                String
    slug                String
    // image | git | dockerfile | nixpacks | buildpacks | static | compose
    sourceType          String
    // JSON: repoUrl, branch, imageRef, dockerfilePath, composeYaml, ...
    sourceConfig        String    @default("{}")
    // JSON: build args, target stage, env-file refs, ...
    buildConfig         String    @default("{}")
    // JSON: healthcheck path/interval/retries (null = none).
    healthcheck         String?
    // running | stopped
    desiredState        String    @default("running")
    replicas            Int       @default(1)
    // Soft pointer to the latest Deployment (no FK, to avoid a relation cycle).
    currentDeploymentId String?   @db.Uuid
    // Auto-deploy on git push (Vercel-style): redeploy when a matching commit lands.
    autoDeploy          Boolean   @default(false)
    // Branch that triggers auto-deploy (falls back to the source branch).
    deployBranch        String?
    // Only auto-deploy when the head commit message matches this (substring, or
    // "regex:<pattern>"); empty = any commit. e.g. "build:".
    commitFilter        String?
    // Last git SHA deployed, for the polling fallback and change detection.
    lastDeployedSha     String?
    // Keep previous deployments running (Railway-style multi-version). Off by
    // default: a new deploy replaces the old container.
    keepReleases        Boolean   @default(false)
    createdAt           DateTime  @default(now())
    updatedAt           DateTime  @updatedAt

    environment Environment  @relation(fields: [environmentId], references: [id], onDelete: Cascade)
    target      DeployTarget @relation(fields: [targetId], references: [id], onDelete: Cascade)
    domains     Domain[]
    volumes     Volume[]

    @@unique([environmentId, slug])
    @@index([targetId])
}

model ManagedDatabase {
    id                  String   @id @default(uuid(7)) @db.Uuid
    environmentId       String   @db.Uuid
    targetId            String   @db.Uuid
    name                String
    slug                String
    // postgres | mysql | mariadb | mongo | redis
    engine              String
    image               String
    version             String
    volumeName          String
    // Container name = DNS hostname on the proxy network.
    containerName       String
    // Optional published TCP port for external access via a per-db forwarder.
    exposePort          Int?
    // Envelope-encrypted generated credentials (JSON: user/password/database).
    encryptedCredential Bytes?
    credentialNonce     Bytes?
    credentialKeyId     String?
    status              String   @default("provisioning")
    createdAt           DateTime @default(now())
    updatedAt           DateTime @updatedAt

    environment Environment  @relation(fields: [environmentId], references: [id], onDelete: Cascade)
    target      DeployTarget @relation(fields: [targetId], references: [id], onDelete: Cascade)

    @@unique([environmentId, slug])
    @@index([targetId])
}

// One deploy run: a status row plus a pointer to its streamed log file. The log
// itself lives on disk (tailed live), not in the database.
model Deployment {
    id             String    @id @default(uuid(7)) @db.Uuid
    targetId       String    @db.Uuid
    // application | database | stack
    deployableType String
    deployableId   String    @db.Uuid
    // queued | building | deploying | running | failed | cancelled | rolled_back
    status         String    @default("queued")
    imageTag       String?
    commitSha      String?
    // Head commit message when known (auto-deploy webhook / resolved on deploy).
    commitMessage  String?
    // Commit author (GitHub), resolved at deploy time for the deployment avatar.
    authorName      String?
    authorAvatarUrl String?
    // Relative path (under the deploy dir) of the streamed build/deploy log file.
    logPath        String?
    triggeredById  String?   @db.Uuid
    startedAt      DateTime?
    finishedAt     DateTime?
    error          String?
    createdAt      DateTime  @default(now())

    target DeployTarget @relation(fields: [targetId], references: [id], onDelete: Cascade)

    @@index([deployableType, deployableId])
    @@index([targetId])
}

model Domain {
    id            String   @id @default(uuid(7)) @db.Uuid
    applicationId String   @db.Uuid
    hostname      String   @unique
    // auto (free sslip.io/traefik.me) | custom | duckdns
    kind          String   @default("auto")
    targetPort    Int
    https         Boolean  @default(true)
    // When off, the hostname stops serving the app (its route is dropped) but the
    // record is kept so it can be re-enabled from the service's domain settings.
    enabled       Boolean  @default(true)
    // le | internal | none
    certResolver  String   @default("le")
    pathPrefix    String?
    createdAt     DateTime @default(now())

    application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

    @@index([applicationId])
}

// Environment variable or secret, scoped to an application or an environment.
// Polymorphic (no FK) like PolicyAttachment; secrets use the envelope columns.
model EnvVar {
    id             String   @id @default(uuid(7)) @db.Uuid
    // application | environment
    scopeType      String
    scopeId        String   @db.Uuid
    key            String
    isSecret       Boolean  @default(false)
    // Plaintext when not a secret; null when isSecret (see envelope columns).
    value          String?
    encryptedValue Bytes?
    valueNonce     Bytes?
    valueKeyId     String?
    createdAt      DateTime @default(now())
    updatedAt      DateTime @updatedAt

    @@unique([scopeType, scopeId, key])
    @@index([scopeType, scopeId])
}

model Volume {
    id            String   @id @default(uuid(7)) @db.Uuid
    targetId      String   @db.Uuid
    applicationId String?  @db.Uuid
    name          String
    mountPath     String
    // volume | bind | nas
    kind          String   @default("volume")
    // For "volume": the named-volume name. For "bind": a subpath confined under
    // the host volume root. For "nas": a subpath confined under the storage
    // connection's mount (the connection id is prefixed when the plan is built).
    source        String?
    // Storage connection backing a "nas" volume; null for volume/bind.
    connectionId  String?  @db.Uuid
    createdAt     DateTime @default(now())

    target      DeployTarget       @relation(fields: [targetId], references: [id], onDelete: Cascade)
    application Application?       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
    connection  StorageConnection? @relation(fields: [connectionId], references: [id], onDelete: Restrict)

    @@index([applicationId])
    @@index([targetId])
    @@index([connectionId])
}

// One-shot bearer ticket for a terminal/logs WebSocket. The client presents the
// raw token (hashed here) over Sec-WebSocket-Protocol; the sidecar burns it once.
model DeployTicket {
    id           String    @id @default(uuid(7)) @db.Uuid
    tokenHash    String    @unique
    userId       String    @db.Uuid
    targetId     String    @db.Uuid
    // Container id/name (or a host marker) the ticket authorizes.
    containerRef String
    // terminal | logs
    mode         String    @default("terminal")
    expiresAt    DateTime
    usedAt       DateTime?
    createdAt    DateTime  @default(now())

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
}

// ---------------------------------------------------------------------------
// Metrics (time-series consumption history)
// ---------------------------------------------------------------------------

// One raw consumption sample for a subject: a deployed Application container or a
// Drive StorageConnection (a NAS/server). Kept a short window at full resolution
// then folded into MetricRollup, so raw growth stays bounded. Percentages are
// derived at read time from the byte columns - never stored. subjectId is a
// polymorphic reference (no FK) resolved by subjectType. The natural composite
// key (subject + timestamp) is the query index and enforces one sample per tick;
// it is not an enumerable integer, so the UUID-id rule does not apply here.
model MetricSample {
    // app | storage
    subjectType    String
    subjectId      String   @db.Uuid
    ts             DateTime @default(now())
    cpuPercent     Float?
    cpuTempC       Float?
    memUsedBytes   BigInt?
    memTotalBytes  BigInt?
    diskUsedBytes  BigInt?
    diskTotalBytes BigInt?

    @@id([subjectType, subjectId, ts])
    @@index([ts])
}

// Hourly aggregate of MetricSample rows, retained far longer than raw so the
// 7d/30d (and wider) ranges read a compact table instead of scanning raw. The
// avg columns are the charted line; cpuPercentMax preserves spikes that
// averaging would hide. `samples` is how many raw points were folded in.
model MetricRollup {
    subjectType       String
    subjectId         String   @db.Uuid
    // Start of the UTC hour bucket this row aggregates.
    bucket            DateTime
    cpuPercentAvg     Float?
    cpuPercentMax     Float?
    cpuTempCAvg       Float?
    memUsedBytesAvg   BigInt?
    memTotalBytesAvg  BigInt?
    diskUsedBytesAvg  BigInt?
    diskTotalBytesAvg BigInt?
    samples           Int      @default(0)

    @@id([subjectType, subjectId, bucket])
    @@index([bucket])
}
