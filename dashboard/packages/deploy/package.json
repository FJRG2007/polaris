{
    "name": "@polaris/deploy",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "description": "Deploy engine: runtime drivers (compose/swarm), pure builders, Traefik config, and the local/remote execution seam.",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "scripts": {
        "build": "tsup src/index.ts --format esm --dts --clean",
        "typecheck": "tsc --noEmit",
        "test": "vitest run --passWithNoTests"
    },
    "dependencies": {
        "@polaris/core": "0.1.0"
    }
}
