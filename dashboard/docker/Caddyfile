# Polaris reverse proxy. Terminates TLS and forwards to the web container.

# Shared proxy behavior, imported by each site below.
(proxy) {
	encode zstd gzip

	# Large uploads: Drive streams multi-gigabyte files through the app, so the
	# proxy must not cap the body. 32 GiB is a generous ceiling that still stops
	# a runaway request from being truly unbounded; raise it if you move larger
	# objects. The app enforces its own per-request limits on top of this.
	request_body {
		max_size 32GB
	}

	header {
		# Deny framing and MIME sniffing; keep referrers off external origins.
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		# Never advertise the server software.
		-Server
	}

	reverse_proxy web:3000
}

# Public site. A domain (e.g. polaris.example.com) gets automatic HTTPS via
# Let's Encrypt; `:80` or `:443` serve an IP-only host.
{$POLARIS_SITE_ADDRESS} {
	import proxy
	# Force HTTPS for a year, including subdomains (ignored on plain-HTTP sites).
	header Strict-Transport-Security "max-age=31536000; includeSubDomains"
}

# Local-network names, appliance-style (like a UniFi/Synology box): reachable over
# BOTH plain HTTP and HTTPS. HTTPS uses Caddy's internal CA (self-signed, so a
# one-time browser warning), so a browser that insists on HTTPS still connects
# instead of hitting a dead :443 - while http:// keeps working with no warning.
# No ACME is involved for these names. The `mdns` service makes polaris.local
# resolve across the LAN; the installer adds a hosts entry for bare `polaris`.
http://polaris.local, http://polaris {
	import proxy
}
https://polaris.local, https://polaris {
	tls internal
	import proxy
}
