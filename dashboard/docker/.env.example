# Polaris dashboard configuration. Copy to `.env` and fill in.
#
#   cp .env.example .env
#
# The install script generates this file for you with fresh secrets. If you
# write it by hand, GENERATE the two secret values below - never copy the
# placeholders and never reuse them across deployments.

# --- Secrets (generate these; do not copy) ---------------------------------
# 32-byte master key, base64, for envelope-encrypting stored credentials.
#   openssl rand -base64 32
POLARIS_MASTER_KEY=REPLACE_ME_openssl_rand_base64_32
# better-auth signing secret. Any long random string (>= 16 chars, use 32+).
#   openssl rand -base64 48
POLARIS_AUTH_SECRET=REPLACE_ME_long_random_string
# One-time token to create the first administrator at /setup. Registration is
# otherwise invite-only. The installer prints this after it generates .env.
POLARIS_SETUP_TOKEN=REPLACE_ME_setup_token

# --- Database --------------------------------------------------------------
# Credentials for the bundled Postgres container.
POSTGRES_USER=polaris
POSTGRES_PASSWORD=REPLACE_ME_strong_password
POSTGRES_DB=polaris
# Connection string the app uses. Host `postgres` is the compose service name;
# keep user/password/db in sync with the POSTGRES_* values above.
POLARIS_DATABASE_URL=postgresql://polaris:REPLACE_ME_strong_password@postgres:5432/polaris

# --- Public URLs -----------------------------------------------------------
# Address Caddy serves on. A domain enables automatic HTTPS; `:80` serves plain
# HTTP for an IP-only or behind-another-proxy setup.
POLARIS_SITE_ADDRESS=polaris.example.com
# Public origin the app builds links from. Must match how users reach it.
POLARIS_APP_URL=https://polaris.example.com
# Mark session cookies Secure. Keep false for plain-HTTP LAN access
# (http://polaris.local); set true only when served over HTTPS end to end.
POLARIS_SECURE_COOKIES=false

# --- Storage ---------------------------------------------------------------
# Container-local storage and upload scratch space (a mounted volume).
POLARIS_DATA_DIR=/var/lib/polaris

# --- Local network discovery -----------------------------------------------
# Name advertised over mDNS (like homeassistant.local). Reachable at
# <name>.local across the LAN and as bare <name> on the local machine. Also
# trusted by auth. Change only if `polaris` clashes with another device.
POLARIS_MDNS_HOSTNAME=polaris

# --- Reverse proxy trust ---------------------------------------------------
# CIDRs whose X-Forwarded-For is trusted when resolving a client IP. Empty (the
# safe default) trusts no forwarded header. Set to your proxy's network only.
POLARIS_TRUSTED_PROXIES=

# --- Host daemon (full edition only) ---------------------------------------
# Socket + token shared with polaris-hostd. Defaults match the compose volumes;
# only change them if you relocate the shared /run/polaris mount.
POLARIS_HOSTD_SOCKET=/run/polaris/hostd.sock
POLARIS_HOSTD_TOKEN_FILE=/run/polaris/hostd.token

# --- Docker over SSH -------------------------------------------------------
# Set up by `install.sh --ssh` (do not fill by hand). Grants the container a
# dedicated, forced-command SSH key to reach the host Docker Engine for the
# Containers app. Left unset, the SSH connector is simply unavailable.
# POLARIS_SSH_ENABLED=true
# POLARIS_SSH_HOST=host.docker.internal
# POLARIS_SSH_USER=youruser
# POLARIS_SSH_PORT=22
# POLARIS_SSH_KEY=/run/polaris-ssh/id_ed25519
# POLARIS_SSH_KNOWN_HOSTS=/run/polaris-ssh/known_hosts

# --- Updates ---------------------------------------------------------------
# Master switch for auto-update. Effective only in the full edition, where the
# daemon can pull and verify new images.
POLARIS_AUTO_UPDATE=true

# Repository and branch the update checker compares the running build against.
# Defaults are fine for the public project; override only for a fork.
POLARIS_REPO=FJRG2007/polaris
POLARIS_UPDATE_BRANCH=main
# POLARIS_BUILD_SHA is baked into the published image by CI - do not set it here.

# --- Image selection -------------------------------------------------------
# Tag of the published images to run (web + hostd). `latest` tracks releases;
# pin to a version (e.g. dashboard-v0.1.0) for reproducible deployments.
POLARIS_IMAGE_TAG=latest
